# ── My Kitchen — environment configuration ───────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env

# ── Security ─────────────────────────────────────────────────────────────
# SECRET_KEY is LOAD-BEARING and MUST be stable across restarts. If it changes,
# all logins and CSRF tokens break (everyone is logged out, forms reject).
# Generate one ONCE and keep it:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-stable-string

# ── LLM provider ─────────────────────────────────────────────────────────
# Provider: mock | gemini | anthropic   (mock needs no key — useful for testing)
LLM_PROVIDER=gemini
# Leave LLM_MODEL blank to use the provider's code default (gemini-3.5-flash).
LLM_MODEL=

# Supply the key for your chosen provider only.
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# Generation tuning (sensible defaults shown; override only if needed).
LLM_TEMPERATURE=0.8
LLM_MAX_TOKENS=8000
LLM_RECENT_TITLES_N=10

# ── Locale ───────────────────────────────────────────────────────────────
# IANA timezone for displaying stored UTC timestamps (handles GMT/BST).
APP_TIMEZONE=Europe/London

# ── Networking / data (defaults are fine for the bundled compose setup) ──
# Port the app listens on inside the container AND publishes on the host.
MY_KITCHEN_PORT=8000
# DB lives on the mounted volume so it survives rebuilds. Maps to HA /data later.
MY_KITCHEN_DB_PATH=/data/my_kitchen.db

# ── gunicorn sizing (frugal defaults for a 1GB-class Pi) ──────────────────
# Generation is I/O-bound, so threads soak the wait cheaply. Raise only if you
# have RAM headroom and real concurrency. On a Pi sharing RAM with HA, leave as-is.
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
