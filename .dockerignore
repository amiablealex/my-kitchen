# Version control
.git
.gitignore

# Python bytecode / build / envs
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Secrets & local config — NEVER bake into the image
.env
.env.*
!.env.example

# Local SQLite DB + WAL/SHM sidecars
*.db
*.db-wal
*.db-shm

# Mounted data + backups (must never be copied into the image)
data/
backups/

# Eval output (dev artifact)
eval_runs/

# Design docs (not needed at runtime)
docs/

# Editor / OS noise
.vscode/
.idea/
*.swp
.DS_Store
